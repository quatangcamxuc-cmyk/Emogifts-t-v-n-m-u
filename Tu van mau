        <code style="background:#f5f5f5;padding:2px 6px;border-radius:4px;font-size:12px">--disable-web-security</code> khi mở Chrome<br><br>
        <strong>Hoặc cách đơn giản hơn:</strong> Upload file lên Google Drive → Mở bằng Google Docs Viewer → dùng link đó.
      </div>` : ''}
    </div>`;
    showToast('❌ ' + (isCors ? 'Lỗi kết nối — xem hướng dẫn' : e.message));
  }

  btn.disabled = false;
  btnText.textContent = 'Tạo bảng tư vấn với AI';
}

function renderResult(text) {
  let html = text
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    // headings
    .replace(/^#{4} (.+)$/gm,'<h4>$1</h4>')
    .replace(/^#{3} (.+)$/gm,'<h3>$1</h3>')
    .replace(/^#{2} (.+)$/gm,'<h2>$1</h2>')
    .replace(/^#{1} (.+)$/gm,'<h1>$1</h1>')
    // bold/italic
    .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
    .replace(/\*(.+?)\*/g,'<em>$1</em>')
    // blockquote
    .replace(/^&gt; (.+)$/gm,'<blockquote>$1</blockquote>')
    // lists
    .replace(/^[-•] (.+)$/gm,'<li>$1</li>')
    .replace(/(<li>[\s\S]+?<\/li>)/g,'<ul>$&</ul>')
    .replace(/<\/ul>\s*<ul>/g,'');

  // Tables
  const tableRegex = /(\|.+\|\n)+/g;
  html = html.replace(tableRegex, (match) => {
    const lines = match.trim().split('\n').filter(l => l.trim() && !l.match(/^\|[\s\-:|]+\|$/));
    if (lines.length < 2) return match;
    const parseRow = l => l.split('|').slice(1,-1).map(c => c.trim());
    const header = parseRow(lines[0]).map(h => `<th>${h}</th>`).join('');
    const rows = lines.slice(1).map(l => `<tr>${parseRow(l).map(c => `<td>${c}</td>`).join('')}</tr>`).join('');
    return `<table><thead><tr>${header}</tr></thead><tbody>${rows}</tbody></table>`;
  });

  html = html.replace(/\n\n+/g,'<br><br>').replace(/\n/g,'<br>');

  document.getElementById('resultBody').innerHTML = `<div class="ai-result">${html}</div>`;
}

function copyResult() {
  if (!currentResult) return;
  navigator.clipboard.writeText(currentResult).then(() => {
    const btn = document.getElementById('copyBtn');
    btn.textContent = '✅ Đã copy!';
    setTimeout(() => btn.innerHTML = '📋 Copy', 1800);
    showToast('📋 Đã copy nội dung tư vấn!');
  });
}

function renderHistory() {
  const list = document.getElementById('historyList');
  if (!history.length) {
    list.innerHTML = '<div class="history-empty">Chưa có lịch sử tư vấn</div>';
    return;
  }
  list.innerHTML = history.map(h => `
    <div class="history-item" onclick="loadHistory(${h.id})">
      <div class="history-dot"></div>
      <div class="history-info">
        <div class="history-name">${h.label} — ${h.occasion}</div>
        <div class="history-time">${h.time} · ${h.budget}</div>
      </div>
    </div>
  `).join('');
}

function loadHistory(id) {
  const entry = history.find(h => h.id === id);
  if (!entry) return;
  currentResult = entry.result;
  document.getElementById('resultTitle').textContent = `Tư vấn — ${entry.label}`;
  document.getElementById('resultMeta').textContent = `${entry.occasion} · ${entry.budget} · ${entry.time}`;
  renderResult(entry.result);
  document.getElementById('copyBtn').style.display = 'flex';
  document.getElementById('printBtn').style.display = 'flex';
}

function clearHistory() {
  if (!confirm('Xóa toàn bộ lịch sử tư vấn?')) return;
  history = [];
  localStorage.removeItem('emogifts_history');
  renderHistory();
  showToast('🗑️ Đã xóa lịch sử');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// Init
renderHistory();
updateKeyStatus();
if (!getApiKey()) {
  // Auto-open key modal on first use
  setTimeout(() => openKeyModal(), 600);
}
</script>
