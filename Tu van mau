        <div class="loading-step"><div class="step-dot"></div>Soạn nội dung tư vấn chuyên nghiệp</div>
      </div>
    </div>`;

  const apiKey = getApiKey();
  if (!apiKey) {
    btn.disabled = false;
    btnText.textContent = 'Tạo bảng tư vấn với AI';
    resultBody.innerHTML = `<div style="padding:32px;text-align:center">
      <div style="font-size:42px;margin-bottom:16px">🔑</div>
      <div style="font-size:16px;font-weight:600;color:var(--navy);margin-bottom:8px">Cần cài API Key trước</div>
      <div style="font-size:14px;color:var(--text2);margin-bottom:20px;line-height:1.6">
        Nhấn nút <strong>"🔑 Chưa có API key"</strong> góc trên phải<br>để nhập key và bắt đầu sử dụng
      </div>
      <button onclick="openKeyModal()" style="padding:11px 24px;background:var(--navy);color:white;border:none;border-radius:8px;font-size:14px;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;">
        🔑 Cài API Key ngay
      </button>
